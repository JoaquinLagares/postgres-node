<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
</head>

<body>

  <h1>
    <%= title %>
  </h1>

  <a href="/new">Create a user</a>
  <a href="/delete">Delete all users</a>

  <hr>
  <form method="GET" action="/">
    <input type="text" name="search" placeholder="Search users..." />
    <button type="submit">Search</button>
  </form>
  
  <h2>Users:</h2>

  <% if (users && users.length> 0) { %>
    <ul>
      <% users.forEach(user=> { %>
        <li>
          <%= user.username %>
        </li>
        <% }) %>
    </ul>
    <% } else { %>
      <p>No users found.</p>
      <% } %>

</body>

</html>